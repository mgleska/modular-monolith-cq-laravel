includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon
    - vendor/phpstan/phpstan-mockery/extension.neon

parameters:

    level: 6

    paths:
        - app/
        - bootstrap/
        - config/
        - routes/
        - tests/

    excludePaths:
        - bootstrap/cache/*

#    ignoreErrors:
#        - '#PHPDoc tag @var#'
